generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum TodoStatus {
  PENDING
  COMPLETED
}

model Todo {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TodoStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([title])
  @@index([createdAt])
}
